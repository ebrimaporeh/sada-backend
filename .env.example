# ─── Core ────────────────────────────────────────────────────────────────────
SECRET_KEY=your-super-secret-key-change-this-in-production
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# ─── Environment ─────────────────────────────────────────────────────────────
DJANGO_SETTINGS_MODULE=settings.development

# ─── Database ────────────────────────────────────────────────────────────────
# SQLite (default for development)
# SQLite path is set automatically from BASE_DIR — only override for PostgreSQL/MySQL
# DATABASE_URL=postgres://user:password@host:5432/dbname

# PostgreSQL (production)
# DATABASE_URL=postgres://user:password@host:5432/dbname

# MySQL (production)
# DATABASE_URL=mysql://user:password@host:3306/dbname

# ─── Frontend ────────────────────────────────────────────────────────────────
FRONTEND_URL=http://localhost:5173
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# ─── Email ───────────────────────────────────────────────────────────────────
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=your-email@gmail.com
EMAIL_HOST_PASSWORD=your-app-password
DEFAULT_FROM_EMAIL=noreply@yourapp.com

# ─── JWT ─────────────────────────────────────────────────────────────────────
JWT_ACCESS_TOKEN_LIFETIME_MINUTES=60
JWT_REFRESH_TOKEN_LIFETIME_DAYS=7

# ─── Rate Limiting ───────────────────────────────────────────────────────────
API_RATE_LIMIT_ANON=100/hour
API_RATE_LIMIT_USER=1000/hour

# ─── Redis / Celery (uncomment when using background tasks) ──────────────────
# REDIS_URL=redis://localhost:6379/0
# CELERY_BROKER_URL=redis://localhost:6379/0
# CELERY_RESULT_BACKEND=redis://localhost:6379/1

# ─── Storage (uncomment for S3) ──────────────────────────────────────────────
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_STORAGE_BUCKET_NAME=
# AWS_S3_REGION_NAME=us-east-1

# ─── Site Settings ───────────────────────────────────────────────────────────
SITE_NAME=My App
SITE_DESCRIPTION=A great application
CONTACT_EMAIL=support@yourapp.com
